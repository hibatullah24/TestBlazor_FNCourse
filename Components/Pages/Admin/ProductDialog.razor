@inject ProductService ProductService
@inject ISnackbar Snackbar

<MudDialogContent>
    <MudForm @ref="_form" @bind-IsValid="_isValid">
        <div style="display:flex; flex-direction:column; gap:1rem;">

            @if (EditingProduct == null)
            {
                <MudTextField T="string"
                              Label="Product name"
                              @bind-Value="_pName"
                              Required="true"
                              RequiredError="Product name is required."
                              Variant="Variant.Outlined" />

                <MudTextField T="string"
                              Label="Description"
                              @bind-Value="_pDesc"
                              Required="true"
                              RequiredError="Description is required."
                              Lines="3"
                              Variant="Variant.Outlined" />
            }
            else
            {
                <MudText Typo="Typo.body1" Style="font-weight:600; color:#5c3d2e">
                    @EditingProduct.PName
                </MudText>
                <MudText Typo="Typo.body2" Style="color:#a07850">
                    @EditingProduct.Description
                </MudText>
            }

            <MudNumericField T="decimal"
                             Label="Price"
                             @bind-Value="_pPrice"
                             Min="0.01m"
                             Required="true"
                             RequiredError="Price is required."
                             Variant="Variant.Outlined"
                             Adornment="Adornment.Start"
                             AdornmentText="$" />

            <MudNumericField T="int"
                             Label="Stock"
                             @bind-Value="_pStock"
                             Min="0"
                             Required="true"
                             RequiredError="Stock is required."
                             Variant="Variant.Outlined" />

            @* File Upload *@
            <div>
                <MudText Typo="Typo.body2"
                         Style="color:#5c3d2e; font-weight:500; margin-bottom:6px">
                    Product Image (optional)
                </MudText>

                <MudFileUpload T="IBrowserFile"
                               FilesChanged="OnFileChanged"
                               Accept=".jpg,.jpeg,.png,.webp">
                    <ActivatorContent>
                        <MudButton Variant="Variant.Outlined"
                                   StartIcon="@Icons.Material.Filled.CloudUpload"
                                   Style="border-color:#8b5e3c; color:#8b5e3c; text-transform:none;">
                            Upload image
                        </MudButton>
                    </ActivatorContent>
                </MudFileUpload>

                @* Preview *@
                @if (_imagePreview != null)
                {
                    <div style="margin-top:10px; border-radius:10px; overflow:hidden;
                                width:100%; height:160px; border:1px solid #e8c9a0;">
                        <img src="@_imagePreview"
                             style="width:100%; height:100%; object-fit:cover;" />
                    </div>
                }
                else
                {
                    <div style="margin-top:10px; height:160px; border-radius:10px;
                                background:linear-gradient(135deg,#fdf0e6,#e8c9a0);
                                display:flex; align-items:center; justify-content:center;
                                border:2px dashed #c8956c;">
                        <div style="text-align:center">
                            <MudIcon Icon="@Icons.Material.Filled.AddPhotoAlternate"
                                     Style="font-size:40px; color:#c8956c; opacity:0.6" />
                            <MudText Typo="Typo.caption"
                                     Style="color:#a07850; display:block; margin-top:4px">
                                No image selected
                            </MudText>
                        </div>
                    </div>
                }

                @if (_fileName != null)
                {
                    <MudText Typo="Typo.caption" Style="color:#8b5e3c; margin-top:4px">
                        📎 @_fileName
                    </MudText>
                }
            </div>

        </div>
    </MudForm>
</MudDialogContent>

<MudDialogActions>
    <MudButton OnClick="Cancel">Cancel</MudButton>
    <MudButton Variant="Variant.Filled"
               Style="background:#8b5e3c; color:white"
               Disabled="_saving"
               OnClick="Save">
        @if (_saving)
        {
            <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" />
        }
        Save
    </MudButton>
</MudDialogActions>

@code {
    [CascadingParameter] IMudDialogInstance MudDialog { get; set; } = null!;
    [Parameter] public Product? EditingProduct { get; set; }

    MudForm _form = null!;
    bool _isValid;
    bool _saving;

    string _pName = "";
    string _pDesc = "";
    decimal _pPrice = 0.01m;
    int _pStock = 0;

    string? _imagePreview;
    string? _fileName;
    IBrowserFile? _uploadedFile;

    protected override void OnParametersSet()
    {
        if (EditingProduct != null)
        {
            _pPrice = EditingProduct.Price;
            _pStock = EditingProduct.Stock;
        }
    }

    async Task OnFileChanged(IBrowserFile file)
    {
        if (file == null) return;
        _uploadedFile = file;
        _fileName = file.Name;

        // Read file and convert to base64 for preview
        using var stream = file.OpenReadStream(maxAllowedSize: 5 * 1024 * 1024); // 5MB max
        using var ms = new MemoryStream();
        await stream.CopyToAsync(ms);
        var base64 = Convert.ToBase64String(ms.ToArray());
        _imagePreview = $"data:{file.ContentType};base64,{base64}";
    }

    void Cancel() => MudDialog.Cancel();

    async Task Save()
    {
        await _form.Validate();
        if (!_isValid) return;

        _saving = true;

        var result = EditingProduct == null
            ? ProductService.AddProduct(new AddProductRequest
                {
                    PName = _pName,
                    Description = _pDesc,
                    Price = _pPrice,
                    Stock = _pStock
                })
            : ProductService.UpdateProduct(EditingProduct.PId, new UpdateProductRequest
                {
                    Price = _pPrice,
                    Stock = _pStock
                });

        if (result.Success)
        {
            Snackbar.Add(result.Message, Severity.Success);
            MudDialog.Close(DialogResult.Ok(true));
        }
        else
        {
            Snackbar.Add(result.Message, Severity.Error);
        }

        _saving = false;
    }
}